# ── Base de datos ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/stockdb
DATABASE_URL_SYNC=postgresql://user:pass@db:5432/stockdb

# ── Redis (reservado para uso futuro) ────────────
REDIS_URL=redis://redis:6379/0

# ── Logging ──────────────────────────────────────
LOG_LEVEL=INFO

# ── CORS ─────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── WhatsApp Gateway (Self-Hosted) ────────────────
# URL del contenedor whatsapp-gateway (Baileys).
# Se conecta automáticamente vía Docker Compose.
WHATSAPP_GATEWAY_URL=http://whatsapp-gateway:3000

# ── Google OAuth (opcional) ──────────────────────
# Dejar vacío para ocultar el botón de Google.
# Crear credenciales en https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── SMTP para Magic Link (opcional) ──────────────
# Si está vacío, el link mágico se muestra directamente en la UI.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
APP_URL=http://localhost:8001
